# Cluster target
KUBECONFIG=~/.kube/k0s-lab-config

# Managed load orchestration
RUN_LOAD=true
K6_WEB_DASHBOARD=false

# Chaos protocol timing
BASELINE_DURATION=20s
WARMUP_DURATION=20s
CHAOS_DURATION=30s
RECOVERY_DURATION=20s

# Optional path overrides
# Chỉ cần dùng khi không chạy từ repo root hoặc đã đổi cấu trúc thư mục.
# Có thể điền đường dẫn tương đối hoặc tuyệt đối tùy môi trường.

# LOAD_TEST_DIR=./load-testing
# LOAD_RUN_SCRIPT=./load-testing/scripts/run-user-journey.sh
# LOAD_ENV_FILE=./load-testing/scripts-k6/.env.k6
