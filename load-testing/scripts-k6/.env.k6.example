# Mục tiêu
BASE_URL=http://mini-ecommerce.tienphatng237.com
LOGIN_ENDPOINT=/api/v1/users/login
PRODUCTS_ENDPOINT=/api/v1/products
ORDERS_ENDPOINT=/api/v1/orders

# Chỉ giữ một script chính: scripts-k6/user-journey.js
# Tải theo VU đơn giản
VU_START=10
VU_MAX=300
VU_STEP=30
VU_TIME_UNIT=20s
VU_RAMP_DOWN_DURATION=30s

# Xác thực
# Nếu có email và mật khẩu, run-with-env.sh sẽ tự login lấy AUTH_TOKEN.
CUSTOMER_EMAIL=
CUSTOMER_PASSWORD=
AUTH_TOKEN=

# Nhiều customer
# Nếu muốn dùng nhiều customer, đặt CUSTOMER_COUNT > 1
# và cấu hình CUSTOMER_EMAIL_PREFIX + CUSTOMER_EMAIL_DOMAIN.
# Ví dụ:
# CUSTOMER_COUNT=20
# CUSTOMER_EMAIL_PREFIX=k6.customer
# CUSTOMER_EMAIL_DOMAIN=example.test
# Script sẽ login các user:
# k6.customer.1@example.test
# k6.customer.2@example.test
# ...
CUSTOMER_COUNT=1
CUSTOMER_EMAIL_PREFIX=
CUSTOMER_EMAIL_DOMAIN=example.test
CUSTOMER_EMAILS=

# Wrapper một lệnh
SEED_CUSTOMERS_BEFORE_RUN=true
CLEANUP_CUSTOMERS_AFTER_RUN=true
SEED_PRODUCTS_BEFORE_RUN=true
CLEANUP_PRODUCTS_AFTER_RUN=true

# Flow đơn giản
CATALOG_PAGE_SIZE=12
THINK_TIME_MIN=${THINK_TIME_MIN:-0.5}
THINK_TIME_MAX=${THINK_TIME_MAX:-2.0}
REQUEST_TIMEOUT=${REQUEST_TIMEOUT:-30s}

# Seed dữ liệu catalog cho benchmark/chaos
SEED_NAMESPACE=rl-seed
SEED_SELLER_COUNT=2
SEED_PRODUCTS_PER_SELLER=5
SEED_PRODUCT_STOCK=500
SEED_PRODUCT_PRICE=109.9
SEED_USER_PASSWORD=K6Read@12345
